# 通用配置
PORT=5001
REQUEST_TIMEOUT=30

# Facebook 应用配置
# 在 https://developers.facebook.com/apps/ 创建应用后获取
FACEBOOK_APP_ID=your_app_id_here
FACEBOOK_APP_SECRET=your_app_secret_here
REDIRECT_URI=http://localhost:5001/fb/callback
FACEBOOK_SCOPE=ads_read,ads_management

# TikTok Business API 配置
# 在 https://developers.tiktok.com/ 创建应用后获取
TIKTOK_APP_ID=your_tiktok_app_id
TIKTOK_APP_SECRET=your_tiktok_app_secret
TIKTOK_REDIRECT_URI=http://localhost:5001/tiktok/callback
TIKTOK_SCOPE=user.info.basic

# Amazon Ads API 配置
# 这里是 Amazon 广告 API 用的 Login with Amazon，不是 SP-API
# 需要在 Amazon Ads / Login with Amazon 对应应用里配置回调地址
AMAZON_AD_CLIENT_ID=amzn1.application-oa2-client.xxxxx
AMAZON_AD_CLIENT_SECRET=your_amazon_ads_client_secret
AMAZON_AD_REDIRECT_URI=http://localhost:5001/amazon-ads/callback

# Amazon SP-API 配置
# 这里是 Seller Central / SP-API 的授权，不是广告 API
# application_id 对应你在 Amazon SP-API 后台里的 Solution Provider 应用 ID
AMAZON_SP_CLIENT_ID=amzn1.application-oa2-client.xxxxx
AMAZON_SP_CLIENT_SECRET=your_amazon_sp_client_secret
AMAZON_SP_APP_ID=amzn1.sp.solution.xxxxx
AMAZON_SP_REDIRECT_URI=http://localhost:5001/amazon-sp/callback

# 可选：固定 Flask session 密钥，避免服务重启后 state 失效
# FLASK_SECRET_KEY=replace_with_a_random_secret
